# --- Zinit Auto-installation ---
if [[ ! -f $HOME/.local/share/zinit/zinit.git/zinit.zsh ]]; then
    print -P "%F{33}▓▒░ %F{220}Installing Zinit (plugin manager)...%f"
    command mkdir -p "$HOME/.local/share/zinit" && command chmod g-rwX "$HOME/.local/share/zinit"
    command git clone https://github.com/zdharma-continuum/zinit.git "$HOME/.local/share/zinit/zinit.git" && \
        print -P "%F{33}▓▒░ %F{34}Installation complete.%f" || \
        print -P "%F{160}▓▒░ %F{160}Installation error.%f"
fi

# --- Load Zinit ---
source "~/.local/share/zinit/zinit.git/zinit.zsh"
autoload -Uz _zinit
(( ${+functions[_zinit]} )) && _zinit

